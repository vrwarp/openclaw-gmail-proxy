# Copy to .env and fill in. Do NOT commit .env.

# --- OAuth (from your Google Cloud project) ---
# Must match the client used during scripts/oauth_bootstrap.py.
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
# The client secret is provided as a FILE (./secrets/client_secret), not here.

# --- Token encryption ---
# Generate with:  python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
# Encrypts the refresh token at rest in ./secrets/token.json.
TOKEN_ENCRYPTION_KEY=

# --- Admin UI ---
# Long random string; required to log into the admin UI.
# Generate with:  python -c "import secrets;print(secrets.token_urlsafe(32))"
ADMIN_TOKEN=

# --- Backend ---
# "google" for real Gmail; "mock" for a local demo with sample data.
GMAIL_BACKEND=google
