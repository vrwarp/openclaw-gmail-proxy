# Copy to .env and fill in. Do NOT commit .env.
#
# The Gmail OAuth client (id + secret) and the refresh token are configured
# entirely on the admin **Setup** page and stored in the /data volume — no env
# vars or client_secret file needed. Only ADMIN_TOKEN is required below.

# --- Gmail OAuth client (optional pre-seed) ---
# You may pre-fill just the client id here; the Setup page still needs the
# secret. Leave blank to enter both in the UI.
GOOGLE_CLIENT_ID=

# --- Token encryption (optional) ---
# Generate with:  python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
# Encrypts the refresh token at rest. If blank, a key is generated once and kept
# in /data/keys/token_fernet.key (back that up with the volume).
TOKEN_ENCRYPTION_KEY=

# --- Admin UI ---
# Long random string. With Google login enabled it is the BREAK-GLASS fallback;
# without Google login it is the only way in. Required in production.
# Generate with:  python -c "import secrets;print(secrets.token_urlsafe(32))"
ADMIN_TOKEN=

# --- Admin UI: "Sign in with Google" (optional) ---
# Create a separate OAuth *Web application* client in the same Google Cloud
# project and register the redirect URI below. Login is restricted to the
# proxied account (ADMIN_ALLOWED_EMAIL, or auto-pinned to the mailbox address).
# Leave the client id/secret blank to disable Google login (token-only).
ADMIN_OAUTH_CLIENT_ID=
ADMIN_OAUTH_CLIENT_SECRET=
ADMIN_OAUTH_REDIRECT_URI=http://localhost:8081/auth/callback
# Optional: pin the allowed login account explicitly (defaults to the proxied
# mailbox's own address). ADMIN_ALLOWED_SUB pins the immutable Google user id.
ADMIN_ALLOWED_EMAIL=
ADMIN_ALLOWED_SUB=

# --- Backend ---
# "google" for real Gmail; "mock" for a local demo with sample data.
GMAIL_BACKEND=google
